{
  "manifest_version": 3,
  "name": "Sentinel Guard",
  "version": "1.0",
  "description": "Real-time phishing detection powered by Lumina Trust Core.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}